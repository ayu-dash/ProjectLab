<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header - Top App Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:gravity="center_vertical"
            android:background="@color/bg_light">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/detail_projek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:text="@string/detail_projek"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_notifications" />
        </LinearLayout>

        <!-- Bottom Border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/black" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/sticky_bottom_action">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Tag: SUKARELA -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/black"
                android:paddingLeft="12dp"
                android:paddingTop="4dp"
                android:paddingRight="12dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tv_detail_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sukarela"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/space_grotesk_bold" />
            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/crypto_analytics_dashboard_20"
                android:textSize="28sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

            <!-- Owner -->
            <TextView
                android:id="@+id/tv_detail_owner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/oleh_aditya_perkasa"
                android:textSize="15sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_regular" />

            <!-- Featured Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                android:background="@color/black"
                android:padding="3dp">

                <ImageView
                    android:id="@+id/iv_detail_banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/white"
                    android:scaleType="centerCrop" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:background="@color/black" />

            <!-- About Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tentang_projek"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/kami_sedang_membangun_iterasi"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                android:background="@color/black" />

            <!-- Open Roles Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_yang_dibuka"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <!-- Dynamic Roles Container -->
            <LinearLayout
                android:id="@+id/roles_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <!-- Loading View -->
            <ProgressBar
                android:id="@+id/pb_detail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom Action -->
    <LinearLayout
        android:id="@+id/sticky_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@color/bg_light_80"
        android:padding="20dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_brutalist_selected"
            android:text="@string/lamar_sekarang"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
