<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/cari_proyek"
            android:textSize="22sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_notifications"
            android:alpha="0.5" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/black"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Search Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/masukkan_kata_kunci"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_brutalist_border"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="32dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/kata_kunci"
                    android:textSize="15sp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/gray_dark"
                    android:fontFamily="@font/space_grotesk"
                    android:imeOptions="actionSearch"
                    android:inputType="text" />

                <ImageView
                    android:id="@+id/btn_do_search"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search" />
            </LinearLayout>

            <!-- Filter Role Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/filter_role"
                    android:textSize="18sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold" />

                <TextView
                    android:id="@+id/btn_pilih_semua_roles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/pilih_semua"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk" />
            </LinearLayout>

            <!-- Role Options (Simplified Grid) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/filter_developer"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_brutalist_selected"
                        android:text="@string/developer"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/filter_designer"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_brutalist_border"
                        android:text="@string/designer"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:layout_marginHorizontal="4dp" />

                    <TextView
                        android:id="@+id/filter_marketer"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_brutalist_border"
                        android:text="@string/marketer"
                        android:textColor="@color/black"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/filter_writer"
                    android:layout_width="120dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_brutalist_border"
                    android:text="@string/writer"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:fontFamily="@font/space_grotesk_bold" />
            </LinearLayout>

            <!-- Tipe Proyek Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tipe_proyek"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/filter_sukarela"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_brutalist_selected"
                    android:text="@string/sukarela"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/filter_berbayar"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_brutalist_border"
                    android:text="@string/berbayar"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginHorizontal="4dp" />

                <TextView
                    android:id="@+id/filter_bagi_hasil"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_brutalist_border"
                    android:text="@string/bagi_hasil"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Recent Searches Section -->
            <LinearLayout
                android:id="@+id/section_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/pencarian_terakhir"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold" />

                    <TextView
                        android:id="@+id/btn_clear_recent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hapus_semua"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/red_dark"
                        android:fontFamily="@font/space_grotesk" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/container_recent_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Results Section (Initially Hidden) -->
            <LinearLayout
                android:id="@+id/section_results"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_result_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hasil_pencarian"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk"
                    android:layout_marginBottom="16dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_search_results"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
