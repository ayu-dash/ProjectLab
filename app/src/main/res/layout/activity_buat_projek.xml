<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header - Top App Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:gravity="center_vertical"
            android:background="@color/bg_light">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:text="@string/buat_projek"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

        </LinearLayout>

        <!-- Bottom Border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/black" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nama Projek -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nama_projek"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_nama_projek"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_brutalist_unselected"
                android:hint="@string/nama_projek_kamu"
                android:textColorHint="@color/gray_lighter"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:textSize="16sp"
                android:fontFamily="@font/space_grotesk_regular"
                android:layout_marginBottom="24dp" />

            <!-- Banner Projek -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/banner_projek"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/container_banner"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginBottom="4dp">

                <ImageView
                    android:id="@+id/iv_banner"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_brutalist_dashed"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:id="@+id/btn_pilih_gambar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_brutalist_selected"
                    android:paddingLeft="24dp"
                    android:paddingRight="24dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pilih_gambar"
                        android:textSize="12sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold" />
                </LinearLayout>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rekomendasi_ukuran_1200x630px"
                android:textSize="10sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk"
                android:layout_marginBottom="24dp" />

            <!-- Deskripsi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/deskripsi"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_deskripsi"
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:background="@drawable/bg_brutalist_unselected"
                android:hint="@string/jelaskan_detail_projek_kamu"
                android:textColorHint="@color/gray_lighter"
                android:gravity="top|start"
                android:padding="16dp"
                android:textSize="15sp"
                android:fontFamily="@font/space_grotesk"
                android:layout_marginBottom="24dp" />

            <!-- Tipe Kompensasi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tipe_kompensasi"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btn_sukarela"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_brutalist_selected"
                    android:text="@string/sukarela_1"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:id="@+id/btn_bagi_hasil"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:text="@string/bagi_hasil_1"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginRight="8dp" />

                <TextView
                    android:id="@+id/btn_berbayar"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:text="@string/berbayar_1"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold" />
            </LinearLayout>

            <!-- Role Yang Dibutuhkan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/role_yang_dibutuhkan"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/et_posisi"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:hint="@string/posisi_eg_designer"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:textSize="15sp"
                    android:fontFamily="@font/space_grotesk"
                    android:layout_marginRight="8dp" />

                <EditText
                    android:id="@+id/et_slot"
                    android:layout_width="70dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:hint="@string/slot"
                    android:gravity="center"
                    android:inputType="number"
                    android:textSize="15sp"
                    android:fontFamily="@font/space_grotesk"
                    android:layout_marginRight="8dp" />

                <FrameLayout
                    android:id="@+id/btn_add_role"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_brutalist_selected"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_add"
                        android:layout_gravity="center"
                        app:tint="@color/black" />
                </FrameLayout>
            </LinearLayout>

            <!-- Added Roles -->
            <LinearLayout
                android:id="@+id/container_roles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Sticky Bottom Action -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light_80"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btn_posting"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_brutalist_selected"
            android:text="@string/posting_projek"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:fontFamily="@font/space_grotesk_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
