<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="@color/bg_light"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            android:layout_marginRight="16dp" />

        <TextView
            android:text="@string/detail_lamaran"
            android:textSize="22sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/black"
        app:layout_constraintTop_toBottomOf="@id/header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@id/layout_actions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Status Section -->
            <TextView
                android:id="@+id/tv_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/menunggu"
                android:gravity="center"
                android:textSize="28sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:background="@drawable/bg_brutalist_yellow_shadow"
                android:padding="16dp"
                android:layout_marginBottom="24dp" />

            <!-- Project Info Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_dashed"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tv_project_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/neobanking_app"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:text="@string/role"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/space_grotesk_regular"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tv_role"
                        android:text="@string/uiux_designer"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/tanggal"
                        android:textSize="12sp"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/space_grotesk_regular"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content" />
                    <TextView
                        android:id="@+id/tv_date"
                        android:text="@string/str_12_jan_2024"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Portofolio Section -->
            <TextView
                android:text="@string/portofolio_yang_disertakan"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/container_portfolios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">
                <!-- Dynamic portfolio items here -->
            </LinearLayout>

            <!-- Message Section -->
            <TextView
                android:text="@string/pesan_tambahan"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_brutalist_border"
                android:padding="16dp"
                android:text="@string/saya_sangat_tertarik_dengan_pr"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk"
                android:layout_marginBottom="24dp" />

            <!-- Contact Section (Visible if Accepted) -->
            <LinearLayout
                android:id="@+id/layout_contact_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:text="HUBUNGI PEMILIK PROJEK"
                    android:textSize="12sp"
                    android:textColor="@color/gray"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_brutalist_yellow_shadow"
                    android:padding="16dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:id="@+id/tv_contact_wa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="WhatsApp: -"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk"
                        android:layout_marginTop="8dp"
                        android:drawableStart="@drawable/ic_open_in_new"
                        android:drawablePadding="8dp" />

                    <TextView
                        android:id="@+id/tv_contact_discord"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Discord: -"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk"
                        android:layout_marginTop="4dp"
                        android:drawableStart="@drawable/ic_open_in_new"
                        android:drawablePadding="8dp" />

                    <TextView
                        android:id="@+id/tv_contact_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Email: -"
                        android:textSize="14sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk"
                        android:layout_marginTop="4dp"
                        android:drawableStart="@drawable/ic_open_in_new"
                        android:drawablePadding="8dp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/layout_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/batalkan_lamaran"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/space_grotesk_bold"
            android:background="@drawable/bg_brutalist_red_shadow"
            android:textAllCaps="true" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
