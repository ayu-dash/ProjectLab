<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFDF7FF">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center_vertical"
        android:background="#FFFFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PROJECTLAB"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF1D1B20"
            android:fontFamily="Space Grotesk" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginRight="16dp"
            android:src="@drawable/ic_icon" /> <!-- Placeholder for Search -->

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_icon" /> <!-- Placeholder for Notification -->
    </LinearLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FF1D1B20"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <!-- Filters -->
    <LinearLayout
        android:id="@+id/filters"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center_vertical"
        android:background="#FFFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/divider1">

        <!-- Semua (Selected) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="@drawable/bg_brutalist_selected"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center"
            android:text="SEMUA"
            android:textColor="#FF1D1B20"
            android:textStyle="bold"
            android:textSize="12sp"
            android:fontFamily="Space Grotesk" />

        <!-- Sukarela -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginLeft="8dp"
            android:background="@drawable/bg_brutalist_border"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center"
            android:text="SUKARELA"
            android:textColor="#FF1D1B20"
            android:textStyle="bold"
            android:textSize="12sp"
            android:fontFamily="Space Grotesk" />

        <!-- Berbayar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginLeft="8dp"
            android:background="@drawable/bg_brutalist_border"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:gravity="center"
            android:text="BERBAYAR"
            android:textColor="#FF1D1B20"
            android:textStyle="bold"
            android:textSize="12sp"
            android:fontFamily="Space Grotesk" />
    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#FF1D1B20"
        app:layout_constraintTop_toBottomOf="@id/filters" />

    <!-- Content (Scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider2"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Card 1 (Yellow) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_selected"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[DEVELOPER, 3 ROLE LAINNYA]"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:background="#FF1D1B20"
                        android:paddingLeft="8dp"
                        android:paddingTop="2dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="2dp"
                        android:text="SUKARELA"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="REVOLUSI URBAN FARMING"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF1D1B20"
                    android:fontFamily="Space Grotesk" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Platform manajemen kebun hidroponik berbasis"
                    android:textSize="14sp"
                    android:textColor="#FF1D1B20"
                    android:fontFamily="Space Grotesk" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FF1D1B20"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 PELAMAR"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="LIHAT ->"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Card 2 (White) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_brutalist_border"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="[UI/UX DESIGNER]"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:background="#FF1D1B20"
                        android:paddingLeft="8dp"
                        android:paddingTop="2dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="2dp"
                        android:text="BERBAYAR"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="REDESIGN PORTAL DESA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FF1D1B20"
                    android:fontFamily="Space Grotesk" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Memperbarui antarmuka layanan publik digital"
                    android:textSize="14sp"
                    android:textColor="#FF1D1B20"
                    android:fontFamily="Space Grotesk" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#FF1D1B20"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 PELAMAR"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="LIHAT ->"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FF1D1B20"
                        android:fontFamily="Space Grotesk" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FAB -->
    <LinearLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_brutalist_selected"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+"
            android:textSize="32sp"
            android:textColor="#FF1D1B20"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFFFF"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Home -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FF1D1B20"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_icon" /> <!-- Placeholder for Home -->
        </LinearLayout>

        <!-- Projects -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_icon" /> <!-- Placeholder for Projects -->
        </LinearLayout>

        <!-- Briefcase -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_icon" /> <!-- Placeholder for Briefcase -->
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_icon" /> <!-- Placeholder for Profile -->
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>