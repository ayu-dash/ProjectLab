<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_brutalist_unselected"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_category_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projek"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <TextView
                android:id="@+id/tv_project_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/judul_projek"
                android:textSize="20sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tv_status_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/black"
            android:text="@string/buka"
            android:textColor="@color/white"
            android:paddingLeft="12dp"
            android:paddingTop="6dp"
            android:paddingRight="12dp"
            android:paddingBottom="6dp"
            android:textSize="12sp"
            android:fontFamily="@font/space_grotesk_bold" />
    </LinearLayout>

    <!-- Stats Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginRight="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/pelamar"
                android:textSize="10sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk" />

            <TextView
                android:id="@+id/tv_applicants_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/str_0"
                android:textSize="24sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/progres_tim"
                android:textSize="10sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView
                    android:id="@+id/tv_team_progress_current"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_0"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold" />

                <TextView
                    android:id="@+id/tv_team_progress_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/str_0_1"
                    android:textSize="14sp"
                    android:textColor="@color/gray"
                    android:fontFamily="@font/space_grotesk_bold"
                    android:layout_marginLeft="4dp"
                    android:layout_marginBottom="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@drawable/dash_line"
        android:layerType="software"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/btn_kelola"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/kelola_projek"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/btn_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_projek"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</LinearLayout>
