<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tunjukkan_karyamu"
                android:textSize="28sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

            <TextView
                android:id="@+id/tv_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@color/black"
                android:paddingLeft="8dp"
                android:paddingTop="4dp"
                android:paddingRight="8dp"
                android:paddingBottom="4dp"
                android:text="@string/str_2_2"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/link_ini_jadi_senjata_utamamu"
            android:textSize="16sp"
            android:textColor="@color/gray"
            android:fontFamily="@font/space_grotesk_medium" />

        <!-- Portofolio Info -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/portofolio"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold" />

        <LinearLayout
            android:id="@+id/container_links"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_portfolio"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_brutalist_shadow"
                android:hint="@string/httpsbehancenetusername"
                android:autofillHints=""
                android:inputType="textUri"
                android:padding="16dp"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_lighter"
                android:fontFamily="@font/space_grotesk_regular" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_tambah_link"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_brutalist_yellow_shadow"
            android:padding="16dp"
            android:gravity="center"
            android:text="TAMBAH LINK LAINNYA"
            android:drawableStart="@drawable/ic_add"
            android:drawablePadding="8dp"
            app:drawableTint="@color/black"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Info Box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_light_alt"
            android:padding="16dp"
            android:layout_marginTop="24dp">
            
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/kamu_bisa_update_link_ini_kapa"
                android:textSize="14sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_regular" />
        </LinearLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btn_finish"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/black"
            app:cornerRadius="0dp"
            android:text="@string/mulai_jelajahi"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/space_grotesk_bold" />

        <TextView
            android:id="@+id/btn_lewati"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:text="@string/lewati_dulu"
            android:gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/gray"
            android:fontFamily="@font/space_grotesk_bold" />

    </LinearLayout>
</ScrollView>
