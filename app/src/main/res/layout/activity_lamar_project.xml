<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header - Top App Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:gravity="center_vertical"
            android:background="@color/bg_light">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/lamar_projek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:text="@string/lamar_projek"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />
        </LinearLayout>

        <!-- Bottom Border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/black" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/sticky_bottom_action">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Role Selection Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/role_yang_kamu_lamar"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <!-- Radio Group Custom -->
            <RadioGroup
                android:id="@+id/rg_roles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
            </RadioGroup>

            <!-- Portfolio Selection Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pilih_portofolio"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/pilih_link_yang_ingin_kamu_ser"
                android:textSize="14sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_regular" />

            <!-- Portfolio List -->
            <LinearLayout
                android:id="@+id/container_portfolios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">
            </LinearLayout>

            <!-- Summary Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_brutalist_dashed"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_description_outline" />

                <TextView
                    android:id="@+id/tv_summary_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="12dp"
                    android:text="@string/kamu_melamar_sebagai_di_pastik"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_regular" />
            </LinearLayout>

            <!-- Message Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/pesan_tambahan_optional"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_bold" />

            <EditText
                android:id="@+id/et_message"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_brutalist_unselected"
                android:padding="16dp"
                android:hint="@string/ceritakan_kenapa_kamu_tertarik"
                android:gravity="top"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:textColorHint="@color/gray_lighter"
                android:fontFamily="@font/space_grotesk_regular" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom Action -->
    <LinearLayout
        android:id="@+id/sticky_bottom_action"
        android:layout_width="match_parent"
        android:layout_height="96dp"
        android:background="@color/bg_light_80"
        android:padding="20dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_send_application"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_brutalist_selected"
            android:text="@string/kirim_lamaran"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
