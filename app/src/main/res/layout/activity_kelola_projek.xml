<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Header - Top App Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:gravity="center_vertical"
            android:background="@color/bg_light">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="16dp"
                android:text="@string/kelola_projek_1"
                android:textSize="22sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/black" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_project_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ui_redesign_for_ecommerce"
                android:textSize="28sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_projek"
                android:textSize="10sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/btn_buka_projek"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_brutalist_selected"
                    android:text="@string/buka_projek"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_regular"
                    android:layout_marginRight="4dp" />

                <TextView
                    android:id="@+id/btn_tutup_projek"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:text="@string/tutup_projek"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_regular" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_brutalist_unselected"
                    android:layout_marginRight="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_pelamar"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/space_grotesk_regular" />

                    <TextView
                        android:id="@+id/tv_total_pelamar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_24"
                        android:textSize="32sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_brutalist_unselected">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/progres_tim"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:textColor="@color/gray"
                        android:fontFamily="@font/space_grotesk_regular" />

                    <TextView
                        android:id="@+id/tv_progres_tim"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/str_25"
                        android:textSize="32sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/space_grotesk_bold" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/daftar_pelamar"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="16dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_pelamar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/tim_saat_ini"
                    android:textSize="18sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold" />

                <TextView
                    android:id="@+id/tv_team_slot_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/slot_25_terisi"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:fontFamily="@font/space_grotesk_bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Sticky Bottom Action -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_light_80"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/btn_simpan_perubahan"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_brutalist_selected"
            android:text="@string/posting_perubahan"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:gravity="center"
            android:fontFamily="@font/space_grotesk_bold" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
