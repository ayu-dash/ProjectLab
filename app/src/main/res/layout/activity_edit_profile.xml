<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:gravity="center_vertical"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="@color/black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDIT PROFIL"
            android:textSize="20sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold"
            android:layout_marginStart="16dp" />
    </LinearLayout>

    <View
        android:id="@+id/divider_top"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/black"
        app:layout_constraintTop_toBottomOf="@id/top_bar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/divider_top"
        app:layout_constraintBottom_toTopOf="@id/divider_bottom">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA LENGKAP"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_brutalist_shadow"
                android:hint="Nama kamu"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/black"
                android:layout_marginBottom="24dp" />

            <!-- Role -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROLE UTAMA"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_role"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_brutalist_shadow"
                android:layout_marginBottom="24dp"
                android:paddingHorizontal="8dp" />

            <!-- WhatsApp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMOR WHATSAPP"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_wa"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_brutalist_shadow"
                android:hint="62812..."
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/black"
                android:inputType="phone"
                android:layout_marginBottom="24dp" />

            <!-- Discord -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USERNAME DISCORD"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/et_discord"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_brutalist_shadow"
                android:hint="username#0000"
                android:paddingHorizontal="16dp"
                android:textSize="14sp"
                android:fontFamily="@font/space_grotesk"
                android:textColor="@color/black"
                android:layout_marginBottom="24dp" />

            <!-- Portfolios -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PORTOFOLIO"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/container_links"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/btn_tambah_link"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_brutalist_yellow_shadow"
                android:text="TAMBAH LINK"
                android:gravity="center"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="8dp"
                app:drawableTint="@color/black"
                android:paddingHorizontal="24dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

    <View
        android:id="@+id/divider_bottom"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/black"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom" />

    <LinearLayout
        android:id="@+id/layout_bottom"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/white"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@color/black"
            android:text="SIMPAN PERUBAHAN"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:fontFamily="@font/space_grotesk_bold"
            app:cornerRadius="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
