<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFFFF">

    <!-- Frame: 1. Login Screen (390x884) -->

    <!-- FRAME: Background Watermark -->
    <LinearLayout
        android:id="@+id/background_watermark"
        android:orientation="vertical"
        android:layout_width="550dp"
        android:layout_height="384dp"
        android:layout_marginStart="-120dp"
        android:layout_marginTop="328dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- TEXT: Text -->
        <TextView
            android:id="@+id/text"
            android:text="PL"
            android:textSize="480sp"
            android:textColor="#08494551"
            android:gravity="start"
            android:textStyle="bold"
            android:fontFamily="Space Grotesk"
            android:layout_width="550dp"
            android:layout_height="384dp" />
    </LinearLayout>

    <!-- FRAME: Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/container"
        android:layout_width="390dp"
        android:layout_height="212dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="180dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- FRAME: Status Badge -->
        <LinearLayout
            android:id="@+id/status_badge"
            android:orientation="horizontal"
            android:layout_width="121dp"
            android:layout_height="25dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="40dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:background="#FFFFFFFF"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp">

            <!-- RECTANGLE: Background -->
            <LinearLayout
                android:id="@+id/background"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_rounded" />

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="87dp"
                android:layout_height="15dp">

                <!-- TEXT: Text -->
                <TextView
                    android:id="@+id/text"
                    android:text="SYSTEM_READY"
                    android:textSize="10sp"
                    android:textColor="#FF1D1B20"
                    android:gravity="start"
                    android:textStyle="bold"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="87dp"
                    android:layout_height="15dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: Connection Pulse SVG -->
        <LinearLayout
            android:id="@+id/connection_pulse_svg"
            android:orientation="vertical"
            android:layout_width="128dp"
            android:layout_height="64dp"
            android:layout_marginStart="48dp"
            android:layout_marginTop="128dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- FRAME: SVG -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/svg"
                android:layout_width="128dp"
                android:layout_height="48dp">

                <!-- VECTOR: Vector -->
                <ImageView
                    android:id="@+id/vector"
                    android:src="@drawable/ic_vector"
                    android:scaleType="fitXY"
                    android:layout_width="120dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="6dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="128dp"
                android:layout_height="12dp">

                <!-- TEXT: CON_PULSE: ACTIVE -->
                <TextView
                    android:id="@+id/con_pulse__active"
                    android:text="CON_PULSE: ACTIVE"
                    android:textSize="8sp"
                    android:textColor="#FF1D1B20"
                    android:gravity="start"
                    android:textStyle="bold"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="128dp"
                    android:layout_height="12dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: Geometric Brutalist Shapes -->
        <LinearLayout
            android:id="@+id/geometric_brutalist_shapes"
            android:orientation="vertical"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="278dp"
            android:layout_marginTop="53dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="64dp"
                android:layout_height="64dp">

                <!-- RECTANGLE: Overlay+Border -->
                <LinearLayout
                    android:id="@+id/overlay_border"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="#0D1D1B20" />

                <!-- RECTANGLE: Overlay+Border -->
                <LinearLayout
                    android:id="@+id/overlay_border"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="#33FFE500" />

                <!-- FRAME: Border -->
                <LinearLayout
                    android:id="@+id/border"
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <!-- FRAME: Container -->
                <LinearLayout
                    android:id="@+id/container"
                    android:orientation="horizontal"
                    android:layout_width="64dp"
                    android:layout_height="64dp">

                    <!-- FRAME: Container -->
                    <LinearLayout
                        android:id="@+id/container"
                        android:orientation="vertical"
                        android:layout_width="18dp"
                        android:layout_height="18dp">

                        <!-- VECTOR: Icon -->
                        <ImageView
                            android:id="@+id/icon"
                            android:src="@drawable/ic_icon"
                            android:scaleType="fitXY"
                            android:layout_width="18dp"
                            android:layout_height="18dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- FRAME: Wireframe element -->
        <LinearLayout
            android:id="@+id/wireframe_element"
            android:orientation="vertical"
            android:layout_width="116dp"
            android:layout_height="136dp"
            android:layout_marginStart="127dp"
            android:layout_marginTop="43dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- FRAME: Border -->
            <LinearLayout
                android:id="@+id/border"
                android:orientation="horizontal"
                android:layout_width="96dp"
                android:layout_height="96dp">

                <!-- RECTANGLE: Border -->
                <LinearLayout
                    android:id="@+id/border"
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <!-- RECTANGLE: Horizontal Divider -->
                <LinearLayout
                    android:id="@+id/horizontal_divider"
                    android:layout_width="94dp"
                    android:layout_height="1dp"
                    android:background="#FF1D1B20" />

                <!-- RECTANGLE: Vertical Divider -->
                <LinearLayout
                    android:id="@+id/vertical_divider"
                    android:layout_width="1dp"
                    android:layout_height="94dp"
                    android:background="#FF1D1B20" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- FRAME: Accent Markers -->
    <LinearLayout
        android:id="@+id/accent_markers"
        android:orientation="vertical"
        android:layout_width="30dp"
        android:layout_height="32dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="836dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- TEXT: Text -->
        <TextView
            android:id="@+id/text"
            android:text="[L]"
            android:textSize="24sp"
            android:textColor="#331D1B20"
            android:gravity="start"
            android:textStyle="bold"
            android:fontFamily="Space Grotesk"
            android:layout_width="30dp"
            android:layout_height="32dp" />
    </LinearLayout>

    <!-- FRAME: Main Interaction Canvas: Moved Auth to Bottom -->
    <LinearLayout
        android:id="@+id/main_interaction_canvas__moved_auth_to_bottom"
        android:orientation="vertical"
        android:layout_width="390dp"
        android:layout_height="493dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="391dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingLeft="20dp"
        android:paddingTop="163.5dp"
        android:paddingRight="20dp"
        android:paddingBottom="48dp">

        <!-- FRAME: Login Card with Neo-Brutalist styling -->
        <LinearLayout
            android:id="@+id/login_card_with_neo_brutalist_styling"
            android:orientation="vertical"
            android:layout_width="350dp"
            android:layout_height="281dp">

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="350dp"
                android:layout_height="222dp">

                <!-- FRAME: Margin -->
                <LinearLayout
                    android:id="@+id/margin"
                    android:orientation="vertical"
                    android:layout_width="350dp"
                    android:layout_height="32dp"
                    android:paddingLeft="0dp"
                    android:paddingTop="0dp"
                    android:paddingRight="0dp"
                    android:paddingBottom="8dp">

                    <!-- FRAME: Container -->
                    <LinearLayout
                        android:id="@+id/container"
                        android:orientation="horizontal"
                        android:layout_width="350dp"
                        android:layout_height="24dp">

                        <!-- FRAME: Background+Border -->
                        <LinearLayout
                            android:id="@+id/background_border"
                            android:orientation="vertical"
                            android:layout_width="238dp"
                            android:layout_height="24dp"
                            android:background="#FF1D1B20"
                            android:paddingLeft="12dp"
                            android:paddingTop="4dp"
                            android:paddingRight="12dp"
                            android:paddingBottom="4dp">

                            <!-- TEXT: Label → AUTHENTICATION REQUIRED -->
                            <TextView
                                android:id="@+id/label___authentication_required"
                                android:text="AUTHENTICATION REQUIRED"
                                android:textSize="12sp"
                                android:textColor="#FFFFFFFF"
                                android:gravity="start"
                                android:textStyle="bold"
                                android:fontFamily="Space Grotesk"
                                android:layout_width="210dp"
                                android:layout_height="12dp" />
                        </LinearLayout>

                        <!-- RECTANGLE: HorizontalBorder -->
                        <LinearLayout
                            android:id="@+id/horizontalborder"
                            android:layout_width="104dp"
                            android:layout_height="3dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- FRAME: Overlay+Border+Shadow+OverlayBlur -->
                <LinearLayout
                    android:id="@+id/overlay_border_shadow_overlayblur"
                    android:orientation="vertical"
                    android:layout_width="350dp"
                    android:layout_height="182dp"
                    android:background="#80FFFFFF"
                    android:paddingLeft="16dp"
                    android:paddingTop="16dp"
                    android:paddingRight="16dp"
                    android:paddingBottom="16dp">

                    <!-- FRAME: Google Login Button -->
                    <LinearLayout
                        android:id="@+id/google_login_button"
                        android:orientation="horizontal"
                        android:layout_width="312dp"
                        android:layout_height="64dp"
                        android:background="#FF1D1B20">

                        <!-- FRAME: SVG -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/svg"
                            android:layout_width="24dp"
                            android:layout_height="24dp">

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
                                android:layout_width="11dp"
                                android:layout_height="10dp"
                                android:layout_marginStart="12dp"
                                android:layout_marginTop="10dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
                                android:layout_width="17dp"
                                android:layout_height="9dp"
                                android:layout_marginStart="2dp"
                                android:layout_marginTop="14dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
                                android:layout_width="5dp"
                                android:layout_height="10dp"
                                android:layout_marginStart="1dp"
                                android:layout_marginTop="7dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
                                android:layout_width="17dp"
                                android:layout_height="9dp"
                                android:layout_marginStart="2dp"
                                android:layout_marginTop="1dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- FRAME: Container -->
                        <LinearLayout
                            android:id="@+id/container"
                            android:orientation="vertical"
                            android:layout_width="215dp"
                            android:layout_height="24dp">

                            <!-- TEXT: Text -->
                            <TextView
                                android:id="@+id/text"
                                android:text="MASUK DENGAN GOOGLE"
                                android:textSize="16sp"
                                android:textColor="#FFFFFFFF"
                                android:gravity="center"
                                android:fontFamily="Space Grotesk"
                                android:layout_width="215dp"
                                android:layout_height="24dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- FRAME: GitHub Login Button -->
                    <LinearLayout
                        android:id="@+id/github_login_button"
                        android:orientation="horizontal"
                        android:layout_width="312dp"
                        android:layout_height="64dp"
                        android:background="#FF1D1B20">

                        <!-- FRAME: SVG -->
                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/svg"
                            android:layout_width="24dp"
                            android:layout_height="24dp">

                            <!-- VECTOR: Vector -->
                            <ImageView
                                android:id="@+id/vector"
                                android:src="@drawable/ic_vector"
                                android:scaleType="fitXY"
                                android:layout_width="24dp"
                                android:layout_height="23dp"
                                android:layout_marginStart="0dp"
                                android:layout_marginTop="0dp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>

                        <!-- FRAME: Container -->
                        <LinearLayout
                            android:id="@+id/container"
                            android:orientation="vertical"
                            android:layout_width="210dp"
                            android:layout_height="24dp">

                            <!-- TEXT: Text -->
                            <TextView
                                android:id="@+id/text"
                                android:text="MASUK DENGAN GITHUB"
                                android:textSize="16sp"
                                android:textColor="#FFFFFFFF"
                                android:gravity="center"
                                android:fontFamily="Space Grotesk"
                                android:layout_width="210dp"
                                android:layout_height="24dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- FRAME: Container -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/container"
                android:layout_width="350dp"
                android:layout_height="35dp">

                <!-- TEXT: Text -->
                <TextView
                    android:id="@+id/text"
                    android:text="Dengan masuk, kamu setuju
dengan syarat layanan ProjectLab."
                    android:textSize="14sp"
                    android:textColor="#FF494551"
                    android:gravity="start"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="235dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="0dp"
                    android:layout_marginTop="-1dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>

        <!-- RECTANGLE: Brutalist Decorative Marker -->
        <LinearLayout
            android:id="@+id/brutalist_decorative_marker"
            android:layout_width="8dp"
            android:layout_height="128dp"
            android:background="#FF1D1B20" />

        <!-- FRAME: Extra Bottom Decorator -->
        <LinearLayout
            android:id="@+id/extra_bottom_decorator"
            android:orientation="vertical"
            android:layout_width="170dp"
            android:layout_height="26dp">

            <!-- FRAME: Margin -->
            <LinearLayout
                android:id="@+id/margin"
                android:orientation="vertical"
                android:layout_width="170dp"
                android:layout_height="14dp"
                android:paddingLeft="0dp"
                android:paddingTop="0dp"
                android:paddingRight="0dp"
                android:paddingBottom="4dp">

                <!-- FRAME: Container -->
                <LinearLayout
                    android:id="@+id/container"
                    android:orientation="vertical"
                    android:layout_width="170dp"
                    android:layout_height="10dp">

                    <!-- TEXT: Text -->
                    <TextView
                        android:id="@+id/text"
                        android:text="PROJECT LAB // CORE INFRASTRUCTURE"
                        android:textSize="10sp"
                        android:textColor="#FF1D1B20"
                        android:gravity="end"
                        android:textStyle="bold"
                        android:fontFamily="Space Grotesk"
                        android:layout_width="170dp"
                        android:layout_height="10dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- RECTANGLE: Background -->
            <LinearLayout
                android:id="@+id/background"
                android:layout_width="128dp"
                android:layout_height="4dp"
                android:background="#FF1D1B20" />

            <!-- FRAME: Margin -->
            <LinearLayout
                android:id="@+id/margin"
                android:orientation="vertical"
                android:layout_width="64dp"
                android:layout_height="8dp"
                android:paddingLeft="0dp"
                android:paddingTop="4dp"
                android:paddingRight="0dp"
                android:paddingBottom="0dp">

                <!-- RECTANGLE: Background -->
                <LinearLayout
                    android:id="@+id/background"
                    android:layout_width="64dp"
                    android:layout_height="4dp"
                    android:background="#FF1D1B20" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- FRAME: Header Section: Yellow Block -->
    <LinearLayout
        android:id="@+id/header_section__yellow_block"
        android:orientation="vertical"
        android:layout_width="390dp"
        android:layout_height="180dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="#FFFFE500"
        android:paddingLeft="20dp"
        android:paddingTop="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp">

        <!-- FRAME: Heading 1:margin -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/heading_1_margin"
            android:layout_width="350dp"
            android:layout_height="102dp">

            <!-- FRAME: Heading 1 -->
            <LinearLayout
                android:id="@+id/heading_1"
                android:orientation="vertical"
                android:layout_width="350dp"
                android:layout_height="94dp"
                android:layout_marginStart="0dp"
                android:layout_marginTop="-1dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <!-- TEXT: Text -->
                <TextView
                    android:id="@+id/text"
                    android:text="PROJECT
LAB"
                    android:textSize="52sp"
                    android:textColor="#FF1D1B20"
                    android:gravity="start"
                    android:textStyle="bold"
                    android:fontFamily="Space Grotesk"
                    android:layout_width="205dp"
                    android:layout_height="94dp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- FRAME: Container -->
        <LinearLayout
            android:id="@+id/container"
            android:orientation="vertical"
            android:layout_width="350dp"
            android:layout_height="222dp">

            <!-- TEXT: Temukan tim. Wujudkan ide. -->
            <TextView
                android:id="@+id/temukan_tim__wujudkan_ide_"
                android:text="Temukan tim. Wujudkan ide."
                android:textSize="18sp"
                android:textColor="#FF1D1B20"
                android:gravity="start"
                android:textStyle="bold"
                android:fontFamily="Space Grotesk"
                android:layout_width="350dp"
                android:layout_height="22dp" />
        </LinearLayout>

        <!-- FRAME: Tech Corner Decorators -->
        <LinearLayout
            android:id="@+id/tech_corner_decorators"
            android:orientation="horizontal"
            android:layout_width="31dp"
            android:layout_height="15dp">

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="12dp"
                android:layout_height="15dp">

                <!-- VECTOR: Icon -->
                <ImageView
                    android:id="@+id/icon"
                    android:src="@drawable/ic_icon"
                    android:scaleType="fitXY"
                    android:layout_width="12dp"
                    android:layout_height="12dp" />
            </LinearLayout>

            <!-- FRAME: Container -->
            <LinearLayout
                android:id="@+id/container"
                android:orientation="vertical"
                android:layout_width="15dp"
                android:layout_height="15dp">

                <!-- VECTOR: Icon -->
                <ImageView
                    android:id="@+id/icon"
                    android:src="@drawable/ic_icon"
                    android:scaleType="fitXY"
                    android:layout_width="15dp"
                    android:layout_height="15dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
