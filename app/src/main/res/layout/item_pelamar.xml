<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_brutalist_unselected"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/iv_pelamar_avatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_brutalist_unselected"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_profile" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginLeft="12dp">

            <TextView
                android:id="@+id/tv_pelamar_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/alex_choi"
                android:textSize="16sp"
                android:textColor="@color/black"
                android:fontFamily="@font/space_grotesk_bold" />

            <TextView
                android:id="@+id/tv_pelamar_role"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/uiux_designer"
                android:textSize="11sp"
                android:textColor="@color/gray"
                android:fontFamily="@font/space_grotesk_regular" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_pelamar_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pesan tambahan dari pelamar..."
        android:textSize="13sp"
        android:textColor="@color/black"
        android:fontFamily="@font/space_grotesk_regular"
        android:layout_marginBottom="12dp"
        android:padding="12dp"
        android:background="#0D000000" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/black_10"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/container_links"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp">
        <!-- Dynamic links will be added here -->
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_terima"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_brutalist_selected"
            android:text="@string/terima"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="@color/black"
            android:fontFamily="@font/space_grotesk_bold"
            android:layout_marginRight="8dp" />

        <ImageView
            android:id="@+id/btn_tolak"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_brutalist_red_shadow"
            android:src="@drawable/ic_close"
            android:padding="8dp"
            app:tint="@color/white" />
    </LinearLayout>

</LinearLayout>
